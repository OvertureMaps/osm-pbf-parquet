# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Test outputs
parquet/
out/
*.osm.pbf
*.osm
*.parquet

# Allow vendored osmpbf test fixtures
!osmpbf/tests/*.osm.pbf
!osmpbf/tests/*.osh.pbf
!osmpbf/tests/*.osm

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb
